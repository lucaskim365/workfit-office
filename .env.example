# Firebase 웹 클라이언트 설정 (VITE_ 접두사 = 클라이언트 노출용)
# Vercel 환경변수(Production/Preview/Development)에 동일 키로 등록하고,
# 로컬은 .env.local 에 값을 채워 사용하세요. (.env.local 은 git 제외)
VITE_FB_API_KEY="your-api-key"
VITE_FB_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FB_PROJECT_ID="your-project-id"
VITE_FB_APP_ID="your-app-id"
VITE_FB_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FB_MESSAGING_SENDER_ID="your-sender-id"
# (선택) 명명된 Firestore 데이터베이스 ID. 기본 DB면 비워두세요.
VITE_FB_FIRESTORE_DB_ID=""

# 로그인 게이트. "true" 일 때만 로그인 화면이 뜬다.
# 콘솔 Auth(이메일/비번 공급자 + 계정) 준비가 끝나면 "true"로 켜세요.
VITE_AUTH_ENABLED="false"
